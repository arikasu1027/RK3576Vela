include $(TOPDIR)/Make.defs

# Board source files
CSRCS = kickpi_k7_bringup.c

# Board include directory
INCDIR = $(INCDIR_PREFIX)$(CONFIG_ARCH_CHIP)

# Build the board library
libboard.a: $(CSRCS:.c=.o)
	$(AR) rcs $@ $^

# Clean
clean:
	rm -f *.o *.a

distclean: clean
	rm -f Makefile

-include $(DEPDIR)/*.d
